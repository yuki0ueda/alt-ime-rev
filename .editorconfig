root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.ahk]
# AutoHotkey v2 は UTF-8 BOM 付きが安全（日本語文字列の扱い）
charset = utf-8-bom
end_of_line = crlf
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[{*.yml,*.yaml}]
indent_size = 2
